MAX_SAMPLES=8137 bash examples/train/distill_client_122b.sh

H=/mnt/tidal-alsh01/dataset/pai/zhaofei4/huawei

# 1) kill detached launcher from pid files
for f in "$H"/distill_client_122b_*.pid; do
  [ -f "$f" ] || continue
  pid="$(cat "$f")"
  echo "killing launcher pid=$pid from $f"
  kill "$pid" 2>/dev/null || true
done

sleep 5

# 2) fallback: kill old distill client + old 122B vLLM server
pkill -f "scripts/distill_client_messages.py" || true
pkill -f "vllm serve .*/qwen3.5-vl-122B" || true
pkill -f "vllm serve /mnt/tidal-alsh01/dataset/pai/zhaofei4/huawei/qwen3.5-vl-122B" || true

# 3) confirm port 8100 is free / show leftovers
sleep 3
ps -ef | grep -E "distill_client_122b|distill_client_messages.py|vllm serve|8100" | grep -v grep || echo "clean"
curl -sf http://localhost:8100/health && echo "WARNING: 8100 still alive" || echo "8100 free"
