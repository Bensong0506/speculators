+       --allowed-local-media-path "$MEDIA_ROOT" \
+       --trust-remote-code \
+       --max-model-len "$GEN_MAX_MODEL_LEN" \
+       --max-num-batched-tokens "$GEN_MAX_MODEL_LEN" \
