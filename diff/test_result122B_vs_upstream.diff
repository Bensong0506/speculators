+   ALLAVA_IMAGE_ROOT=<real image path on training node> \
+   MAX_SAMPLES=50 EPOCHS=1 VALIDATE_INITIAL=0 \
+   bash examples/train/nohup_dflash_122b_allava_distilled.sh
