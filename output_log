# 整个 kv_transfer 目录结构（看有没有单独的 engine 包装类）
ls -R $KV

# 找 engine 的导入、初始化、注册、传输调用
grep -rnE "import mooncake|from mooncake|TransferEngine|ascend_transport|ascend_direct" $KV
grep -rnE "def initialize|\.initialize\(|register_memory|register_buffer|register\(" $KV
grep -rnE "transfer_sync|transfer_async|batch_transfer|\.read\(|\.write\(|TransferOpcode|OpCode|READ|WRITE" $KV
grep -rnE "local_hostname|get_local_ip|host_name|session_id|segment|rpc_port|device_name|protocol" $KV
