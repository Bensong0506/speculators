# 原生 / baseline MTP —— 复用 eval-guidellm harness (METHOD=mtp)
# 由 run_mtp_accept_compare.sh 通过 env 注入路径;也可直接
#   bash examples/evaluate/eval-guidellm/run_evaluation.sh -c npu_mtp_accept/configs/mtp-native.env
BASE_MODEL="${NATIVE_MTP_MODEL:?set NATIVE_MTP_MODEL=/abs/path/to/native-9b}"
SPECULATOR_MODEL="${NATIVE_MTP_DRAFT:-}"        # 留空=内置 MTP 头;独立 speculator 才填
METHOD="mtp"
NUM_SPEC_TOKENS="${NUM_SPEC_TOKENS:-3}"

# 数据集:内网不通 HF 时改成本地 jsonl,如 DATASET=/home/wenxuan/data/math.jsonl
DATASET="${DATASET:-RedHatAI/speculator_benchmarks:math_reasoning.jsonl}"

TENSOR_PARALLEL_SIZE="${TP:-1}"
MAX_MODEL_LEN="${MAX_MODEL_LEN:-8192}"
GPU_MEMORY_UTILIZATION="${GPU_MEM_UTIL:-0.85}"
PORT="${NATIVE_PORT:-8000}"
HEALTH_CHECK_TIMEOUT="${HEALTH_TIMEOUT:-600}"
TOKENIZER_MODE="auto"
NO_CHUNKED_PREFILL="true"

TEMPERATURE="${TEMP:-0.6}"
TOP_P=0.95
TOP_K=20

OUTPUT_DIR="${OUT_NATIVE:-./npu_mtp_accept/results/native}"
