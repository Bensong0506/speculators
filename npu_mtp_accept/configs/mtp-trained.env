# 你训好的 MTP —— 复用 eval-guidellm harness (METHOD=mtp)
# 与 mtp-native.env 唯一实质差别:模型路径 + 端口 + 输出目录
BASE_MODEL="${TRAINED_MTP_MODEL:?set TRAINED_MTP_MODEL=/abs/path/to/your-trained-9b-mtp}"
SPECULATOR_MODEL="${TRAINED_MTP_DRAFT:-}"       # 留空=内置 MTP 头;独立 speculator 才填
METHOD="${MTP_METHOD:-mtp}"                      # trained≈native 时改 qwen3_5_mtp 重试
NUM_SPEC_TOKENS="${NUM_SPEC_TOKENS:-3}"

DATASET="${DATASET:-RedHatAI/speculator_benchmarks:math_reasoning.jsonl}"

TENSOR_PARALLEL_SIZE="${TP:-1}"
MAX_MODEL_LEN="${MAX_MODEL_LEN:-8192}"
GPU_MEMORY_UTILIZATION="${GPU_MEM_UTIL:-0.85}"
PORT="${TRAINED_PORT:-8000}"
HEALTH_CHECK_TIMEOUT="${HEALTH_TIMEOUT:-600}"
TOKENIZER_MODE="auto"
NO_CHUNKED_PREFILL="true"

TEMPERATURE="${TEMP:-0.6}"
TOP_P=0.95
TOP_K=20

OUTPUT_DIR="${OUT_TRAINED:-./npu_mtp_accept/results/trained}"
